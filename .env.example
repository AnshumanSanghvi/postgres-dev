# =============================================================================
# Postgres Dev Environment — environment variables
# Copy to .env (gitignored) and adjust as needed. Defaults are dev-safe.
# =============================================================================

# Bootstrap superuser password — used by initdb on first boot.
# (Slices S1-S8 connect as `postgres` with this password.)
POSTGRES_PASSWORD=postgres

# Application user passwords — used in S9+ to create admin/developer/app users.
POSTGRES_ADMIN_PASSWORD=admin
POSTGRES_DEVELOPER_PASSWORD=developer
POSTGRES_APP_PASSWORD=app

# Default application database name (created in S8+).
POSTGRES_DB=appdb

# Barman replication user (S17). Used by Barman to stream WAL and run
# pg_basebackup. Has REPLICATION + LOGIN attributes only — no DML/DDL.
BARMAN_USER=barman_repl
BARMAN_PASSWORD=barman
