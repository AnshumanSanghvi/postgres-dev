# Local environment
.env
*.local

# Volume-mounted runtime data — must never be committed.
# Use directory contents pattern (not directory itself) so .gitkeep can be re-included.
volumes/data/*
volumes/logs/*
!volumes/data/.gitkeep
!volumes/logs/.gitkeep

# Claude Code session state (per-user, not project)
.claude/

# OS / editor noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/
